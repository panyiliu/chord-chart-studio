# ===== Docker compose ports =====
# Frontend app exposed port (host)
APP_HOST_PORT=8080
# Frontend app internal port (container nginx)
APP_CONTAINER_PORT=80

# Backup proxy exposed port (host)
BACKUP_PROXY_HOST_PORT=8787
# Backup proxy internal port (container node service)
BACKUP_PROXY_CONTAINER_PORT=8787

# ===== Backup proxy runtime env =====
BACKUP_PROXY_PORT=8787
# Use explicit origin in production, e.g. https://your-domain.com
BACKUP_PROXY_CORS_ORIGIN=*

# ===== Docker image tags (local build default; for GHCR use ghcr.io/<YOUR_USER>/chord-chart-studio:tag) =====
CHORD_STUDIO_IMAGE=chord-chart-studio:local
BACKUP_PROXY_IMAGE=chord-chart-studio-backup-proxy:local
